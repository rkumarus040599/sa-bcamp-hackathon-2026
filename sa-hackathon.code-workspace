{
  "folders": [
    {
      "path": "."
    }
  ],
  "settings": {
    "files.exclude": {
      "**/.DS_Store": true,
      "**/node_modules": true,
      "**/dist": true
    },
    "search.exclude": {
      "**/node_modules": true,
      "**/dist": true
    },
    "editor.formatOnSave": true,
    "files.trimTrailingWhitespace": true
  },
  "extensions": {
    "recommendations": [
      "yzhang.markdown-all-in-one",
      "redhat.vscode-yaml",
      "ms-azuretools.vscode-docker"
    ]
  }
}

